import numpy as np
import pandas as pd
import matplotlib.pyplot as plt 

df = pd.read_csv("//Users/macbook/Desktop/Fccu project /fccu_energy_consumption_raw.csv")
print(df)
# now explore data and find out ! what problems in row data 
print(df.shape)
